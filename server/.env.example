# =============================================================================
# ViVaWav3 — server environment (copy to .env and fill in; never commit .env)
# =============================================================================

# --- Server ---
PORT=3001
NODE_ENV=development

# Comma-separated allowed browser origins for CORS (include Vite dev URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# Google Gemini (protocol / Hardware_Protocol JSON generation)
# https://ai.google.dev/gemini-api/docs
# =============================================================================
GEMINI_API_KEY=
# Model id (examples: gemini-2.0-flash, gemini-1.5-flash)
GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# ElevenLabs (voice-guided breathing TTS)
# https://elevenlabs.io/docs
# =============================================================================
ELEVENLABS_API_KEY=
# Voice id from ElevenLabs dashboard (optional; server may default)
ELEVENLABS_VOICE_ID=

# =============================================================================
# Firebase Admin SDK (Express writes sessions / recovery scores to Firestore or RTDB)
# Option A — path to service account JSON (recommended for local dev)
# Option B — set GOOGLE_APPLICATION_CREDENTIALS instead of FIREBASE_SERVICE_ACCOUNT_PATH
# =============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# If you use the standard Google env var, you can omit FIREBASE_SERVICE_ACCOUNT_PATH:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Firestore (default) vs Realtime Database — set if using RTDB URL for legacy paths
# FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com

# =============================================================================
# Hydrawav3 platform API (workshop credentials; protocol / device integration)
# =============================================================================
HYDRAWAV3_API_BASE_URL=
HYDRAWAV3_API_KEY=

# =============================================================================
# Fallbacks (match requirements: pre-recorded audio when ElevenLabs fails)
# =============================================================================
VOICE_COACHING_FALLBACK_AUDIO_URL=

# =============================================================================
# Optional: local development only — skip Firebase ID token verification on
# GET /api/clients and GET /api/recovery/:userId (never enable in production)
# =============================================================================
# DEV_BYPASS_AUTH=false
