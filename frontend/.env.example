# =============================================================================
# ViVaWav3 — Vite frontend (copy to .env.local; only VITE_* vars are exposed)
# =============================================================================

# Base URL for Express API (Vite dev proxy forwards /api; use this for absolute URLs if needed)
VITE_API_BASE_URL=http://localhost:3001

# =============================================================================
# Firebase client (Auth + Firestore or Realtime Database listeners)
# From Firebase Console → Project settings → Your apps → Web app config
# =============================================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Only if you use Realtime Database:
# VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
